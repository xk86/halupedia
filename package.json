{
  "name": "hallupedia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "client": "vite",
    "dev": "concurrently -n vite,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite build --watch --mode development",
    "dev:server": "node --import tsx/esm src/server/index.ts",
    "build": "vite build",
    "check": "npm run typecheck && npm run build",
    "db:reset": "rm -f data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "server": "node --import tsx/esm src/server/index.ts",
    "start": "node --import tsx/esm src/server/index.ts",
    "pretest": "npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:client": "vitest run",
    "test:server": "node --import tsx --test tests/**/*.test.ts",
    "test:media": "node --import tsx --test tests/media.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.vitest.json",
    "rag:audit": "node --import tsx/esm scripts/rag-audit.ts",
    "generate:emoji-names": "node --import tsx/esm scripts/generate-emoji-names.ts",
    "rag:audit:dry": "node --import tsx/esm scripts/rag-audit.ts --dry-run"
  },
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "@hono/node-server": "^2.0.2",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@types/three": "^0.184.1",
    "three": "^0.184.0",
    "diff-match-patch": "^1.0.5",
    "fast-json-patch": "^3.1.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-components": "^1.5.4",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-types": "^0.24.8",
    "hono": "^4.6.14",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.46",
    "markdown-it": "^14.1.1",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-markdown": "^2.1.2",
    "mustache": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "smol-toml": "^1.6.1",
    "toml": "^4.1.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "promptfoo": "^0.121.12",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@9.15.0"
}
