{
  "name": "hallupedia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "client": "vite",
    "dev": "concurrently -n vite,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite build --watch --mode development",
    "dev:server": "node --import tsx/esm src/server/index.ts",
    "build": "vite build",
    "check": "npm run typecheck && npm run build",
    "db:reset": "rm -f data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "server": "node --import tsx/esm src/server/index.ts",
    "prestart": "npm run build",
    "start": "node --import tsx/esm src/server/index.ts",
    "pretest": "npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:client": "vitest run",
    "test:server": "node --import tsx --test tests/**/*.test.ts",
    "test:media": "node --import tsx --test tests/media.test.ts",
    "test:eval": "pnpm dlx promptfoo@0.121.12",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.vitest.json",
    "format": "prettier --write \"src/client/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/client/**/*.{ts,tsx,css}\"",
    "lint:css": "stylelint \"src/client/**/*.css\"",
    "rag:audit": "node --import tsx/esm scripts/rag-audit.ts",
    "generate:emoji-names": "node --import tsx/esm scripts/generate-emoji-names.ts",
    "rag:audit:dry": "node --import tsx/esm scripts/rag-audit.ts --dry-run",
    "db:slug-dupe-check": "node --import tsx/esm scripts/slug-dupe-check.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource/inter": "^5.2.8",
    "@hono/node-server": "^2.0.5",
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@prosekit/extensions": "^0.17.4",
    "@prosekit/pm": "^0.1.18",
    "@tailwindcss/vite": "^4.3.1",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.7.0",
    "3d-force-graph": "^1.80.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "fast-json-patch": "^3.1.1",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-components": "^1.5.4",
    "graphology-metrics": "^2.4.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-types": "^0.24.8",
    "hono": "^4.12.25",
    "tiktoken": "^1.0.15",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.47",
    "lucide-react": "^1.20.0",
    "markdown-it": "^14.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-markdown": "^2.1.2",
    "mustache": "^4.2.0",
    "prosekit": "^0.21.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "three": "^0.184.0",
    "toml": "^4.1.1",
    "troika-three-text": "^0.52.4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "undici": "^7.28.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vite": "^6.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.7.0"
}
