{
  "name": "hallupedia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite build --watch --mode development",
    "dev:server": "node --import tsx/esm src/server/index.ts",
    "build": "vite build",
    "start": "node --import tsx/esm src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.6.14",
    "markdown-it": "^14.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "packageManager": "pnpm@9.15.0"
}
