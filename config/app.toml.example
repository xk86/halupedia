[server]
host = "0.0.0.0"
port = 8787

[storage]
database_path = "data/halupedia.sqlite"

[search]
limit = 20

[rag]
enabled = true
# LanceDB is the canonical retrieval store. Rebuild it after changing the
# embedding model, ontology vocabulary, or document schema.
max_results = 12
min_score = 0.4
# Reference-list tuning (independent of general RAG so it can be tightened/loosened separately).
# reference_max_results caps only newly-discovered vector-search (RAG) results per build.
# Body-linked, user-added, and prior-save references are NOT subject to this cap — they
# are only bounded by max_references. Pinned references survive pruning and don't count toward max_references.
reference_max_results = 8
reference_min_score = 0.5
max_references = 50
reference_recursive_depth = 2
reference_recursive_max_per_article = 2
# Minimum RAG score for a reference's content (summary/chunk) to be included in the
# prompt JSON sent to the LLM. Below this threshold the ref still appears in the list
# so the LLM can link to it, but its text is omitted to keep context windows small.
# Pinned references always include their content regardless of this value.
# Range 0.0–1.0; raise to shrink prompts, lower to give the LLM more source material.
prompt_ref_content_min_score = 0.52
# After the min_score filter, only the top-K highest-scoring refs get their content
# included. Pinned refs are always included and don't count against this cap.
# Set to 0 to disable the cap entirely.
prompt_ref_content_top_k = 6

# Maximum incoming link hints included in generation/rewrite prompts after dedupe.
# Heavily-backlinked articles can have hundreds; uncapped they distract refreshes.
prompt_link_hints_max = 12
# Hard character budget for the retrieved-context block of any prompt.
# Entries past the budget are dropped whole.
prompt_context_max_chars = 24000

# Refresh-specific context caps. Refresh improves an existing article instead of
# writing a new one, so it gets a tighter budget than generation.
refresh_context_max_chars = 4000
refresh_context_max_articles = 4
refresh_related_titles_max = 6

# When true, ontology indexing runs a light-model pass over article prose to
# propose on-vocabulary entities + typed relations, merged with deterministic
# infobox extraction. Runs in the background reindex drainer, cached by article
# content + vocabulary hash so the model is only called when either changes.
ontology_llm_extraction = false

[homepage]
rotation_hours = 4

[world]
# One in-universe day advances every homepage rotation. Change the epoch to
# re-anchor the fictional calendar without changing article content.
epoch_real_time = "2026-01-01T00:00:00.000Z"
epoch_day = 1
epoch_date = "2000-01-01"
calendar_name = "Halu Era"

[random_page]
inspiration_count = 50

[generation]
# Full article-generation workflows admitted at once. Extra misses wait in the
# app queue so trace duration measures active generation time, not queue wait.
max_in_flight = 1

[pipeline.trace]
# Structural tracing of the LangGraph pipeline. Each workflow run records its
# nodes, timings, state diffs, and warnings to a dedicated SQLite database so
# we never have to step through a debugger to understand a generation.
# Disable in production if observation overhead is undesirable.
enabled = true
database_path = "data/halupedia-traces.sqlite"
# off | quiet | normal | debug | trace
#   normal records timings, hashes, validation results, warnings.
#   debug adds state diffs. trace adds full per-node inputs/outputs.
level = "normal"
retention_days = 14

[images]
model_max_edge = 256
jpeg_quality = 70
max_bytes = 15728640
fetch_timeout_ms = 10000
media_database_path = "data/halupedia-media.sqlite"
allow_private_hosts = false

[images.generation]
enabled = false
auto_generate_for_new_articles = false
auto_generate_for_featured_article = false
# Caps automatic homepage image attempts per article/news slug while the server is running.
homepage_auto_image_max_attempts = 3
auto_preset_multipass = false
backend = "openai" # openai | ollama

[images.generation.openai]
base_url = "https://api.openai.com/v1"
api_key = ""
model = "gpt-image-2"
size = "1088x624"
quality = "low"
output_format = "jpeg"
output_compression = 70
timeout_ms = 120000

[images.generation.aspect_ratios.landscape]
label = "landscape"
size = "1088x624"
selection_when = "Ordinary article headline images, places, scenes, objects, and general encyclopedia illustrations."

[images.generation.aspect_ratios.square]
label = "square"
size = "832x832"
selection_when = "Icons, specimens, centered artifacts, album-like covers, badges, symbols, and compact visual subjects."

[images.generation.aspect_ratios.portrait]
label = "portrait"
size = "832x1088"
selection_when = "People, character portraits, statues, fashion, costumes, tall objects, and vertical compositions."

[images.generation.aspect_ratios.poster]
label = "poster portrait"
size = "768x1152"
selection_when = "Posters, covers, propaganda, exhibition placards, title cards, and designed printed artifacts."

[images.generation.aspect_ratios.wide]
label = "wide landscape"
size = "1152x672"
selection_when = "Broad landscapes, group scenes, architecture, maps, ceremonies, battle scenes, or environment-heavy subjects."

[images.generation.ollama]
base_url = "http://127.0.0.1:11434"
model = "x/z-image-turbo"
width = 1088
height = 624
steps = 20
timeout_ms = 120000

[tests]
database_path = "halupedia-testing.sqlite"
llm_base_url = "http://127.0.0.1:11434/v1"
llm_api_key = "ollama"
llm_model = "gemma4"
