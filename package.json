{
  "name": "hallupedia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "client": "vite",
    "dev": "concurrently -n vite,server -c cyan,magenta \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite build --watch --mode development",
    "dev:server": "node --import tsx/esm src/server/index.ts",
    "build": "vite build",
    "check": "npm run typecheck && npm run build",
    "db:reset": "rm -f data/halupedia.sqlite data/halupedia.sqlite-shm data/halupedia.sqlite-wal",
    "server": "node --import tsx/esm src/server/index.ts",
    "start": "node --import tsx/esm src/server/index.ts",
    "pretest": "npm run build",
    "test": "npm run test:server && npm run test:client",
    "test:client": "vitest run",
    "test:server": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.vitest.json",
    "rag:audit": "node --import tsx/esm scripts/rag-audit.ts",
    "rag:audit:dry": "node --import tsx/esm scripts/rag-audit.ts --dry-run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "hono": "^4.6.14",
    "jsonrepair": "^3.14.0",
    "katex": "^0.16.46",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.15.0"
}
